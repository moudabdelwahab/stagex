-- 1. إنشاء جدول المحفظة المركزية
CREATE TABLE IF NOT EXISTS central_wallet (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    balance BIGINT DEFAULT 10000000, -- 10 مليون نقطة
    total_transferred BIGINT DEFAULT 0,
    updated_at TIMESTAMPTZ DEFAULT NOW()
);

-- إدراج السجل الوحيد للمحفظة إذا لم يكن موجوداً
INSERT INTO central_wallet (balance)
SELECT 10000000
WHERE NOT EXISTS (SELECT 1 FROM central_wallet);

-- 2. إضافة حقل تجميد الرصيد لجدول user_wallets إذا لم يكن موجوداً
ALTER TABLE user_wallets ADD COLUMN IF NOT EXISTS is_frozen BOOLEAN DEFAULT FALSE;

-- 3. إنشاء جدول سجل عمليات المحفظة المركزية
CREATE TABLE IF NOT EXISTS central_wallet_transactions (
    id UUID PRIMARY KEY DEFAULT gen_random_uuid(),
    admin_id UUID REFERENCES auth.users(id),
    target_user_id UUID REFERENCES auth.users(id),
    amount BIGINT NOT NULL,
    transaction_type TEXT NOT NULL, -- 'transfer', 'add', 'deduct', 'freeze', 'unfreeze'
    previous_balance BIGINT,
    new_balance BIGINT,
    created_at TIMESTAMPTZ DEFAULT NOW()
);

-- 4. تفعيل RLS
ALTER TABLE central_wallet ENABLE ROW LEVEL SECURITY;
ALTER TABLE central_wallet_transactions ENABLE ROW LEVEL SECURITY;

-- 5. سياسات الوصول (فقط لحساب support@mad3oom.online)
-- ملاحظة: سنعتمد على البريد الإلكتروني للتحقق من الهوية
CREATE POLICY "Only support email can view central wallet" ON central_wallet
    FOR SELECT USING (
        auth.jwt() ->> 'email' = 'support@mad3oom.online'
    );

CREATE POLICY "Only support email can update central wallet" ON central_wallet
    FOR UPDATE USING (
        auth.jwt() ->> 'email' = 'support@mad3oom.online'
    );

CREATE POLICY "Only support email can view transactions" ON central_wallet_transactions
    FOR SELECT USING (
        auth.jwt() ->> 'email' = 'support@mad3oom.online'
    );

CREATE POLICY "Only support email can insert transactions" ON central_wallet_transactions
    FOR INSERT WITH CHECK (
        auth.jwt() ->> 'email' = 'support@mad3oom.online'
    );

-- 6. وظيفة لتحويل النقاط (Atomic Transaction)
CREATE OR REPLACE FUNCTION transfer_points_from_central(
    target_user_email TEXT,
    amount_to_transfer BIGINT
) RETURNS JSONB AS $$
DECLARE
    target_uid UUID;
    current_central_balance BIGINT;
BEGIN
    -- التحقق من صلاحية المستخدم الحالي
    IF auth.jwt() ->> 'email' != 'support@mad3oom.online' THEN
        RETURN jsonb_build_object('success', false, 'message', 'غير مصرح لك بالقيام بهذه العملية');
    END IF;

    -- الحصول على معرف المستخدم المستهدف
    SELECT id INTO target_uid FROM auth.users WHERE email = target_user_email;
    
    IF target_uid IS NULL THEN
        RETURN jsonb_build_object('success', false, 'message', 'المستخدم غير موجود');
    END IF;

    -- الحصول على رصيد المحفظة المركزية الحالي
    SELECT balance INTO current_central_balance FROM central_wallet LIMIT 1;

    IF current_central_balance < amount_to_transfer THEN
        RETURN jsonb_build_object('success', false, 'message', 'رصيد المحفظة المركزية غير كافٍ');
    END IF;

    -- تحديث المحفظة المركزية
    UPDATE central_wallet 
    SET balance = balance - amount_to_transfer,
        total_transferred = total_transferred + amount_to_transfer,
        updated_at = NOW();

    -- تحديث محفظة المستخدم (إنشاء إذا لم تكن موجودة)
    INSERT INTO user_wallets (user_id, available_points, total_points)
    VALUES (target_uid, amount_to_transfer, amount_to_transfer)
    ON CONFLICT (user_id) DO UPDATE 
    SET available_points = user_wallets.available_points + amount_to_transfer,
        total_points = user_wallets.total_points + amount_to_transfer,
        updated_at = NOW();

    -- تسجيل العملية
    INSERT INTO central_wallet_transactions (admin_id, target_user_id, amount, transaction_type, previous_balance, new_balance)
    VALUES (auth.uid(), target_uid, amount_to_transfer, 'transfer', current_central_balance, current_central_balance - amount_to_transfer);

    RETURN jsonb_build_object('success', true, 'message', 'تم تحويل النقاط بنجاح');
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;

-- 7. وظيفة لإدارة رصيد العميل (إضافة/خصم/تجميد)
CREATE OR REPLACE FUNCTION manage_user_points(
    target_user_email TEXT,
    amount_change BIGINT,
    action_type TEXT -- 'add', 'deduct', 'freeze', 'unfreeze'
) RETURNS JSONB AS $$
DECLARE
    target_uid UUID;
BEGIN
    -- التحقق من صلاحية المستخدم الحالي
    IF auth.jwt() ->> 'email' != 'support@mad3oom.online' THEN
        RETURN jsonb_build_object('success', false, 'message', 'غير مصرح لك بالقيام بهذه العملية');
    END IF;

    -- الحصول على معرف المستخدم المستهدف
    SELECT id INTO target_uid FROM auth.users WHERE email = target_user_email;
    
    IF target_uid IS NULL THEN
        RETURN jsonb_build_object('success', false, 'message', 'المستخدم غير موجود');
    END IF;

    IF action_type = 'add' THEN
        UPDATE user_wallets 
        SET available_points = available_points + amount_change,
            total_points = total_points + amount_change,
            updated_at = NOW()
        WHERE user_id = target_uid;
    ELSIF action_type = 'deduct' THEN
        UPDATE user_wallets 
        SET available_points = GREATEST(0, available_points - amount_change),
            updated_at = NOW()
        WHERE user_id = target_uid;
    ELSIF action_type = 'freeze' THEN
        UPDATE user_wallets SET is_frozen = TRUE, updated_at = NOW() WHERE user_id = target_uid;
    ELSIF action_type = 'unfreeze' THEN
        UPDATE user_wallets SET is_frozen = FALSE, updated_at = NOW() WHERE user_id = target_uid;
    END IF;

    -- تسجيل العملية
    INSERT INTO central_wallet_transactions (admin_id, target_user_id, amount, transaction_type)
    VALUES (auth.uid(), target_uid, amount_change, action_type);

    RETURN jsonb_build_object('success', true, 'message', 'تمت العملية بنجاح');
END;
$$ LANGUAGE plpgsql SECURITY DEFINER;
