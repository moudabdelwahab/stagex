
/* Central Wallet Styles */
.central-wallet-btn {
    position: relative;
    color: var(--color-text);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 8px;
    cursor: pointer;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
}

.central-wallet-btn:hover {
    background: var(--color-muted);
    border-color: var(--color-accent);
    color: var(--color-accent);
}

.central-wallet-btn:hover .wallet-tooltip {
    display: block;
}

.wallet-tooltip {
    display: none;
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 8px;
    padding: 12px;
    box-shadow: var(--shadow-lg);
    z-index: 1002;
    min-width: 180px;
    margin-top: 10px;
    text-align: right;
    pointer-events: none;
}

.wallet-tooltip::before {
    content: '';
    position: absolute;
    bottom: 100%;
    left: 50%;
    transform: translateX(-50%);
    border: 8px solid transparent;
    border-bottom-color: var(--color-border);
}

.tooltip-item {
    font-size: 0.85rem;
    margin-bottom: 4px;
    color: var(--color-text-secondary);
}

.tooltip-item span {
    font-weight: 700;
    color: var(--color-text);
}

/* Modal Styles */
.admin-modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.5);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2000;
    backdrop-filter: blur(4px);
}

.modal-content {
    background: var(--color-surface);
    border-radius: 16px;
    width: 90%;
    max-width: 500px;
    box-shadow: var(--shadow-xl);
    overflow: hidden;
}

.modal-header {
    padding: 20px;
    border-bottom: 1px solid var(--color-border);
    display: flex;
    justify-content: space-between;
    align-items: center;
    background: var(--color-muted);
}

.modal-header h2 {
    margin: 0;
    font-size: 1.25rem;
    font-weight: 800;
}

.close-modal {
    background: none;
    border: none;
    font-size: 1.5rem;
    cursor: pointer;
    color: var(--color-text-secondary);
}

.modal-body {
    padding: 24px;
}

.wallet-stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 24px;
}

.stat-card {
    background: var(--color-muted);
    padding: 16px;
    border-radius: 12px;
    text-align: center;
    border: 1px solid var(--color-border);
}

.stat-label {
    display: block;
    font-size: 0.8rem;
    color: var(--color-text-secondary);
    margin-bottom: 8px;
}

.stat-value {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--color-accent);
}

.wallet-actions-form .form-group {
    margin-bottom: 16px;
}

.wallet-actions-form label {
    display: block;
    margin-bottom: 8px;
    font-weight: 600;
    font-size: 0.9rem;
}

.wallet-actions-form input {
    width: 100%;
    padding: 12px;
    border: 1px solid var(--color-border);
    border-radius: 8px;
    background: var(--color-surface);
    color: var(--color-text);
}

.action-buttons {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin-top: 20px;
}

.action-buttons button {
    padding: 12px;
    border: none;
    border-radius: 8px;
    font-weight: 700;
    cursor: pointer;
    transition: opacity 0.2s;
    font-size: 0.85rem;
}

.action-buttons button:hover {
    opacity: 0.9;
}

.btn-primary { background: var(--color-primary); color: white; grid-column: span 2; }
.btn-success { background: #10b981; color: white; }
.btn-danger { background: #ef4444; color: white; }
.btn-warning { background: #f59e0b; color: white; }
.btn-info { background: #3b82f6; color: white; }
